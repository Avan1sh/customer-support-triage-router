# Copy this file to ".env" and fill in your real values.
# .env is git-ignored and must NEVER be committed.

# --- Groq (required) -----------------------------------------------------
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model ID. Groq's available models change over time — check the current list
# at https://console.groq.com/docs/models and update if needed.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional override for the escalation detector model (defaults to GROQ_MODEL).
# GROQ_DETECTOR_MODEL=llama-3.3-70b-versatile

# --- Optional: LangSmith tracing (Phase 5) -------------------------------
# When enabled, LangChain auto-traces every LLM/chain/graph call to a web
# dashboard showing prompts, responses, token counts, and latency.
# Get a free key at https://smith.langchain.com then flip TRACING to true.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=support-triage-router

# --- Email notifications (Gmail SMTP) ------------------------------------
# Sends the customer a "query registered + reply" email.
# Gmail setup:
#   1) Turn ON 2-Step Verification: https://myaccount.google.com/security
#   2) Create an App Password: https://myaccount.google.com/apppasswords
#      (pick "Mail" / "Other") -> you get a 16-character password
#   3) Put that app password (NOT your normal password) in SMTP_PASSWORD below.
# Leave SMTP_PASSWORD blank to run in DRY-RUN (composes + logs, never sends).
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=youraddress@gmail.com
STORE_NAME=Acme Store
